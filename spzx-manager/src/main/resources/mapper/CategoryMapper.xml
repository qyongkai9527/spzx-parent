<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joker.spzx.manager.mapper.CategoryMapper">

    <select id="findCountByParentId" resultType="java.util.Map">

        select parent_id,count(1) as count from category
        where parent_id in (<foreach collection="collect" item="item" separator=",">#{item}</foreach>)
        group by parent_id
    </select>
</mapper>
